# Docker Compose only (not read by the app itself): the uid/gid the container
# runs as. Set these to match the owner of the host directory mounted at
# /srv, so the non-root container user can read/write it.
PUID=1000
PGID=1000

LOG_LEVEL=DEBUG
# Defaults to /srv, which is what the Docker image expects (matches the
# volume mount in compose.yaml). Only set this for local `bun dev`, where
# /srv doesn't exist -- point it at a real folder on your machine instead.
# ROOT_DIR=./
PORT=3000
# Signs the session cookie. If unset, derived from AUTH_PASSWORD (stable
# across restarts). Only needed if you want a key independent of the password.
# SECRET_KEY=
READ_ONLY=false
ALLOW_CREATE=true
ALLOW_DELETE=true
ALLOW_RENAME=true
ALLOW_UPLOAD=true
ALLOW_DOWNLOAD=true
ALLOW_CHMOD=true
# Off by default: changing owner/group usually requires the container to run as root.
ALLOW_CHOWN=false
MAX_FILE_SIZE=10MB
# ALLOWED_EXTENSIONS=json,yaml
# DENY_EXTENSIONS=exe,bat,cmd,sh,js,ts,py,rb,pl
# AUTH_PASSWORD=changeme
AUTH_ENABLED=false

# Where unsaved-edit content for open tabs is kept in the browser: "local"
# (survives browser restarts), "session" (cleared on tab/browser close),
# or "none" (never written to storage; unsaved edits are lost on refresh).
# Frontend-only, inlined at build time. Defaults to "session".
# BUN_PUBLIC_TAB_PERSISTENCE=session