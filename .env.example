LOG_LEVEL=DEBUG
ROOT_DIR=./
PORT=3000
# Signs the session cookie. If unset, derived from AUTH_PASSWORD (stable
# across restarts). Only needed if you want a key independent of the password.
# SECRET_KEY=
READ_ONLY=false
ALLOW_CREATE=true
ALLOW_DELETE=true
ALLOW_RENAME=true
ALLOW_UPLOAD=true
ALLOW_DOWNLOAD=true
MAX_FILE_SIZE=10MB
# ALLOWED_EXTENSIONS=json,yaml
# DENY_EXTENSIONS=exe,bat,cmd,sh,js,ts,py,rb,pl
# AUTH_PASSWORD=changeme
AUTH_ENABLED=false

# Where unsaved-edit content for open tabs is kept in the browser: "local"
# (survives browser restarts), "session" (cleared on tab/browser close),
# or "none" (never written to storage; unsaved edits are lost on refresh).
# Frontend-only, inlined at build time. Defaults to "session".
# BUN_PUBLIC_TAB_PERSISTENCE=session